{
  "expo": {
    "name": "Sylk",
    "slug": "consrcutionapp",
    "scheme": "sylk",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.davidmoretti.constructionmanager",
      "buildNumber": "33",
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:construciton-production.up.railway.app"
      ],
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "whatsapp",
          "sms",
          "googlegmail"
        ],
        "NSMicrophoneUsageDescription": "This app uses the microphone for voice-to-text input when creating tasks, notes, and messages.",
        "NSSpeechRecognitionUsageDescription": "This app uses speech recognition to convert your voice to text for easier communication.",
        "NSCameraUsageDescription": "This app uses the camera to take photos for project documentation, daily reports, and progress tracking.",
        "NSPhotoLibraryUsageDescription": "This app accesses your photo library to attach existing photos to projects, reports, and messages.",
        "NSPhotoLibraryAddUsageDescription": "This app saves project photos and documents to your photo library.",
        "NSLocationWhenInUseUsageDescription": "This app uses your location to calculate distances to job sites and provide location-based services.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1f3a"
      },
      "package": "com.davidmoretti.constructionmanager",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SEND_SMS",
        "android.permission.VIBRATE"
      ],
      "edgeToEdgeEnabled": true,
      "versionCode": 4
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-mail-composer",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "This app accesses your photos for project documentation.",
          "cameraPermission": "This app uses the camera for project photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "This app uses your location to calculate distances to job sites."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2196F3"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d77d2431-4ce6-4ed4-b447-acdc3e6d8f1c"
      },
      "privacyPolicyUrl": "https://construciton-production.up.railway.app/privacy",
      "termsOfServiceUrl": "https://construciton-production.up.railway.app/terms"
    },
    "owner": "davidmoretti",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d77d2431-4ce6-4ed4-b447-acdc3e6d8f1c"
    }
  }
}

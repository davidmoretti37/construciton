#!/bin/bash
# ============================================================
# Pre-Push Hook — Blocks push if any check fails
# ============================================================

export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.nvm/versions/node/$(ls $HOME/.nvm/versions/node 2>/dev/null | tail -1)/bin:$PATH"

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'
BOLD='\033[1m'

echo -e "${BOLD}========================================${NC}"
echo -e "${BOLD}  Pre-Push Validation                   ${NC}"
echo -e "${BOLD}========================================${NC}"

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ── 1. Backend Tests ──────────────────────────────────────
echo -e "\n${BOLD}1. Backend Tests${NC}"
cd "$REPO_ROOT/backend"
if [ ! -d "node_modules" ]; then
  echo "  Installing backend dependencies..."
  /opt/homebrew/bin/npm install --silent 2>/dev/null
fi
echo "  Running backend tests..."
if /opt/homebrew/bin/npx jest --silent 2>&1 | tail -10 | grep -qE "(Tests:.*passed|Test Suites:.*passed)"; then
  echo -e "  ${GREEN}PASS${NC} Backend tests"
else
  echo -e "  ${RED}FAIL${NC} Backend tests"
  /opt/homebrew/bin/npx jest 2>&1 | tail -15
  echo -e "\n${RED}Push blocked — fix backend tests first${NC}"
  exit 1
fi

# ── 2. Frontend Tests ─────────────────────────────────────
echo -e "\n${BOLD}2. Frontend Tests${NC}"
cd "$REPO_ROOT/frontend"
if [ ! -d "node_modules" ]; then
  echo "  Installing frontend dependencies..."
  /opt/homebrew/bin/npm install --silent --legacy-peer-deps 2>/dev/null
fi
echo "  Running frontend tests..."
if /opt/homebrew/bin/npx jest --silent 2>&1 | tail -10 | grep -qE "(Tests:.*passed|Test Suites:.*passed)"; then
  echo -e "  ${GREEN}PASS${NC} Frontend tests"
else
  echo -e "  ${RED}FAIL${NC} Frontend tests"
  /opt/homebrew/bin/npx jest 2>&1 | tail -15
  echo -e "\n${RED}Push blocked — fix frontend tests first${NC}"
  exit 1
fi

# ── 3. TypeScript Check ───────────────────────────────────
echo -e "\n${BOLD}3. TypeScript Check${NC}"
cd "$REPO_ROOT/frontend"
echo "  Running tsc --noEmit..."
if /opt/homebrew/bin/npx tsc --noEmit 2>&1 | grep -q "error TS"; then
  echo -e "  ${RED}FAIL${NC} TypeScript errors found:"
  /opt/homebrew/bin/npx tsc --noEmit 2>&1 | grep "error TS" | head -10
  echo -e "\n${RED}Push blocked — fix TypeScript errors first${NC}"
  exit 1
else
  echo -e "  ${GREEN}PASS${NC} TypeScript — no errors"
fi

# ── 4. Tool Definition Integrity ──────────────────────────
echo -e "\n${BOLD}4. Tool Integrity${NC}"
cd "$REPO_ROOT/backend"
TOOL_CHECK=$(SUPABASE_URL=https://test.supabase.co SUPABASE_SERVICE_ROLE_KEY=test /opt/homebrew/bin/node -e "
  const { toolDefinitions } = require('./src/services/tools/definitions');
  const { TOOL_HANDLERS } = require('./src/services/tools/handlers');
  const defined = toolDefinitions.map(t => t.function.name);
  const missing = defined.filter(n => !TOOL_HANDLERS[n]);
  if (missing.length > 0) {
    console.log('MISSING:' + missing.join(','));
    process.exit(1);
  } else {
    console.log('OK:' + defined.length + ' tools verified');
    process.exit(0);
  }
" 2>&1)

if echo "$TOOL_CHECK" | grep -q "^OK:"; then
  echo -e "  ${GREEN}PASS${NC} $TOOL_CHECK"
else
  echo -e "  ${RED}FAIL${NC} $TOOL_CHECK"
  echo -e "\n${RED}Push blocked — tool definition mismatch${NC}"
  exit 1
fi

# ── Done ──────────────────────────────────────────────────
echo -e "\n${GREEN}${BOLD}All checks passed — push allowed${NC}\n"

# ===========================================
# Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to version control

# -------------------------------------------
# AI Services
# -------------------------------------------

# OpenRouter API - Powers AI chat and analysis features
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq API (OPTIONAL) - Ultra-fast inference for agent routing (300+ tokens/sec)
# If not set, falls back to OpenRouter with Haiku
# Get your key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# -------------------------------------------
# Speech Services
# -------------------------------------------

# Deepgram API - Powers voice-to-text transcription
# Get your key: https://console.deepgram.com/signup
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# -------------------------------------------
# Maps & Location Services
# -------------------------------------------

# Google Maps API - Powers geocoding and distance calculations
# Get your key: https://console.cloud.google.com/apis/credentials
# Required APIs: Geocoding API, Distance Matrix API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# -------------------------------------------
# Stripe Payments
# -------------------------------------------

# Stripe Secret Key - Powers subscription billing
# Get your keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Webhook Secret - For verifying webhook signatures
# Get this after creating webhook endpoint in Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs - Create products in Stripe Dashboard first
# Go to: https://dashboard.stripe.com/test/products
STRIPE_STARTER_PRICE_ID=price_starter_id_here
STRIPE_PRO_PRICE_ID=price_pro_id_here
STRIPE_BUSINESS_PRICE_ID=price_business_id_here

# -------------------------------------------
# Supabase (Backend)
# -------------------------------------------

# Supabase URL and Service Role Key for backend operations
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -------------------------------------------
# Email (Resend)
# -------------------------------------------

# Resend API Key - Powers invoice and estimate emails
# Get your key: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# From address for transactional emails
EMAIL_FROM=Sylk <noreply@sylkapp.ai>

# -------------------------------------------
# Banking - Teller (OPTIONAL)
# -------------------------------------------

# Teller Application ID - Bank connections and transaction sync
# Get from: https://teller.io/developers
TELLER_APPLICATION_ID=your_teller_app_id_here
TELLER_ENV=sandbox

# -------------------------------------------
# App URLs
# -------------------------------------------

# Frontend URL for Stripe return redirects (deep link scheme)
FRONTEND_URL=constructionmanager://

# Backend URL - REQUIRED in production for Stripe checkout redirects
# Set to your Railway/deployment URL (e.g., https://your-app.up.railway.app)
BACKEND_URL=http://localhost:3000

# Portal URL - Client-facing portal base URL (used for CORS, payment redirects, emails)
PORTAL_URL=https://sylkapp.ai/portal

# -------------------------------------------
# Server Configuration
# -------------------------------------------

# IMPORTANT: Set to 'production' in deployment for secure cookies and proper error handling
NODE_ENV=development

# Port for the backend server (default: 3000)
PORT=3000

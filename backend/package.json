{
  "name": "construction-manager-backend",
  "version": "1.0.0",
  "description": "Streaming relay server for Construction Manager AI",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "predeploy": "bash ../scripts/pre-deploy.sh",
    "evals": "node evals/scripts/runEvals.js",
    "evals:smoke": "node evals/scripts/runEvals.js --suite smoke",
    "evals:pull": "node evals/scripts/pull-candidates.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@supabase/supabase-js": "^2.103.0",
    "abort-controller": "^3.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "form-data": "^4.0.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "mammoth": "^1.11.0",
    "node-fetch": "^2.7.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "plaid": "^42.1.0",
    "resend": "^6.10.0",
    "stripe": "^20.4.0",
    "twilio": "^6.0.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
